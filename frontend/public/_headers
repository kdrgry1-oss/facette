# Cloudflare Pages / Netlify _headers
# Amaç: "eski hali bir an görünüp sonra yenisi geliyor" sorununu çözmek.
#
# index.html ASLA cache'lenmez -> her ziyarette en güncel sürüm gelir,
# hash'li statik dosyalar (main.[hash].js/css, /static/*) sonsuza dek cache'lenir
# (içerik değişince dosya adı/hash değiştiği için güvenli ve hızlı).

# HTML her zaman taze
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Hash'li build dosyaları: kalıcı cache
/static/*
  Cache-Control: public, max-age=31536000, immutable

# Diğer hash'li JS/CSS
/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
